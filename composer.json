{
    "name": "jardissupport/workflow",
    "homepage": "https://jardis.io",
    "description": "Directed workflow engine with status-based transitions, automatic data accumulation, and builder API",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contracts": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "phpstan/phpstan": "2.1.56",
        "squizlabs/php_codesniffer": "3.13.5"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Workflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Workflow\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/jardisSupport/workflow/issues",
        "docs": "https://docs.jardis.io/en/support/workflow",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "workflow",
        "orchestration",
        "process-orchestration",
        "state-machine",
        "transitions",
        "steps",
        "domain-driven-design",
        "php",
        "jardis",
        "headgent"
    ]
}
